# RetailGPT — Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.

# ─── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Optional overrides ────────────────────────────────────────────────────────
# Switch model (default: claude-sonnet-4-6)
ANALYST_MODEL=claude-sonnet-4-6
ANALYST_PROVIDER=anthropic

# Use local SQLite prototype DB (default)
DB_URL=sqlite:///./retailgpt_prototype.db

# Set to false to suppress [SYNTHETIC DATA] labels (only when using real data)
SYNTHETIC_DATA_MODE=true

# ─── Production (uncomment when ready) ────────────────────────────────────────
# Databricks AI Gateway (OpenAI-compatible)
# DB_URL=databricks+connector://...
# ANALYST_PROVIDER=openai
# OPENAI_API_KEY=dapi...
# OPENAI_BASE_URL=https://<workspace>.azuredatabricks.net/serving-endpoints

# Gemini infographics (P2 — Step 3)
# GOOGLE_API_KEY=AIza...
